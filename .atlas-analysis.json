  "keyFeatures": [
    "JWT-based authentication with OTP email verification and refresh token rotation",
    "Real-time ride tracking via WebSocket (STOMP) with live driver location updates",
    "Stripe payment integration with checkout session creation and verification",
    "Role-based access control for RIDER and DRIVER roles",
    "Ride lifecycle management: REQUESTED → ACCEPTED → PICKED → COMPLETED/CANCELLED",
    "Nearby driver discovery with geospatial caching",
    "In-app notifications with WebSocket delivery",
    "Ride feedback and rating system for both riders and drivers",
    "Docker Compose deployment with PostgreSQL and Redis",
    "React frontend with Three.js backdrop, Tailwind CSS, and STOMP WebSocket client"
  ],
